{
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "NotebookEdit",
      "LSP",
      "mcp__linear-server",
      "mcp__linear__linear_create_issue",
      "mcp__linear__linear_update_issue",
      "mcp__linear__linear_search_issues",
      "mcp__linear__linear_get_user_issues",
      "mcp__linear__linear_add_comment",
      "Bash(rm -rf ~/Library/Developer/Xcode/DerivedData:*)",
      "Bash(xcodebuild:*)",
      "Bash(swift:*)",
      "Bash(xcrun:*)",
      "Bash(open *.xcodeproj:*)",
      "Bash(open *.xcworkspace:*)",
      "Bash(pod:*)",
      "Bash(cargo:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git stash:*)",
      "Bash(brew:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(gh:*)",
      "Bash(mkdir:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout -- .:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git branch -D:*)",
      "Bash(git stash drop:*)",
      "Bash(git stash clear:*)"
    ]
  }
}
